#!/usr/bin/env python3
# killy-setup — auto-populate install.disks in install-config.yaml.
#
# Run from the build host (inside nix-shell) while killy is booted on the
# installer ISO and reachable over SSH:
#
#   bin/killy-setup <killy-installer-ip>
#
# What this does:
#   1. SSHes into the live installer and collects lsblk output.
#   2. Auto-selects drives: smallest non-USB disk = OS, largest = data.
#   3. Applies default partition layout (see DEFAULTS below).
#   4. Writes the install: section into killy/install-config.yaml and
#      re-encrypts it with SOPS.
#   5. Prints the proposed section for operator review.
#      Edit install-config.yaml manually if the proposal needs adjustment.
#
# No interactive prompts — the proposal is written unconditionally. Review
# the output and edit the YAML if needed before running `install` on killy.
#
import json
import math
import subprocess
import sys
import textwrap
from pathlib import Path

import yaml

REPO_ROOT   = Path(__file__).parent.parent
CONFIG_PATH = REPO_ROOT / "killy" / "install-config.yaml"

# ---------------------------------------------------------------------------
# Defaults applied to all hosts. Edit install-config.yaml after running this
# wizard if you need a different layout.
# ---------------------------------------------------------------------------

EFI_SIZE_MB   = 1024
ROOT_FS       = "btrfs"
ROOT_OPTS     = "compress=zstd,noatime"
DATA_FS       = "btrfs"
DATA_OPTS     = "compress=zstd,noatime"
SUBVOLUMES    = [
    {"name": "@",     "mount": "/"},
    {"name": "@nix",  "mount": "/nix"},
    {"name": "@home", "mount": "/home"},
    {"name": "@log",  "mount": "/var/log"},
]
SRV_SIZE_GB   = 100   # /srv gets 100 GiB; /var/mail gets the remainder


def gb(size_bytes):
    return math.floor(size_bytes / 1024**3)


def ssh_run(host, cmd):
    result = subprocess.run(
        ["ssh", "-o", "StrictHostKeyChecking=no", "-o", "ConnectTimeout=10",
         f"nixos@{host}", cmd],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"SSH error: {result.stderr}", file=sys.stderr)
        sys.exit(1)
    return result.stdout


def update_config(install_section):
    """Decrypt install-config.yaml, set install: key, re-encrypt in place."""
    # Decrypt
    result = subprocess.run(
        ["sops", "decrypt", str(CONFIG_PATH)],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"sops decrypt failed:\n{result.stderr}", file=sys.stderr)
        sys.exit(1)

    config = yaml.safe_load(result.stdout)
    config["install"] = install_section

    # Write plaintext to path matching .sops.yaml path_regex, then encrypt.
    plaintext = yaml.dump(config, default_flow_style=False, allow_unicode=True)
    CONFIG_PATH.write_text(plaintext)

    result = subprocess.run(
        ["sops", "encrypt", "--in-place", str(CONFIG_PATH)],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"sops encrypt failed:\n{result.stderr}", file=sys.stderr)
        sys.exit(1)


def main():
    if len(sys.argv) < 2:
        print(f"Usage: {sys.argv[0]} <killy-installer-ip>", file=sys.stderr)
        sys.exit(1)

    host = sys.argv[1]
    print(f"\nkilly-setup — connecting to nixos@{host} ...")

    # Collect block device info from the live installer.
    raw   = ssh_run(host, "lsblk --json --bytes --output NAME,SIZE,MODEL,TYPE,TRAN")
    data  = json.loads(raw)

    # Physical non-USB disks only.
    drives = [
        d for d in data.get("blockdevices", [])
        if d.get("type") == "disk" and d.get("tran") != "usb"
    ]
    drives.sort(key=lambda d: d["size"])   # ascending by size

    if len(drives) < 1:
        print("No non-USB disks found.", file=sys.stderr)
        sys.exit(1)

    print(f"\nFound {len(drives)} non-USB disk(s):")
    print(f"  {'Device':<15} {'Size (GB)':>10}  Model")
    print(f"  {'-'*15} {'-'*10}  {'-'*30}")
    for d in drives:
        print(f"  {'/dev/'+d['name']:<15} {gb(d['size']):>10}  {(d.get('model') or '').strip()}")

    # Auto-select: smallest = OS, largest = data (if more than one).
    os_drive   = drives[0]
    data_drive = drives[-1] if len(drives) > 1 else None

    os_size_gb   = gb(os_drive["size"])
    os_model     = (os_drive.get("model") or "").strip()

    os_section = {
        "model":              os_model,
        "size_gb":            os_size_gb,
        "efi_size_mb":        EFI_SIZE_MB,
        "root_fs":            ROOT_FS,
        "root_mount_options": ROOT_OPTS,
        "subvolumes":         SUBVOLUMES,
    }

    install_section: dict = {"disks": {"os": os_section}}

    if data_drive:
        data_size_gb  = gb(data_drive["size"])
        data_model    = (data_drive.get("model") or "").strip()
        mail_size_gb  = data_size_gb - SRV_SIZE_GB

        data_section = {
            "model":    data_model,
            "size_gb":  data_size_gb,
            "partitions": [
                {"mount": "/srv",      "size_gb": SRV_SIZE_GB,   "fs": DATA_FS, "mount_options": DATA_OPTS},
                {"mount": "/var/mail", "size_gb": mail_size_gb,  "fs": DATA_FS, "mount_options": DATA_OPTS},
            ],
        }
        install_section["disks"]["data"] = data_section

    # Write and re-encrypt.
    update_config(install_section)

    # Print proposal for operator review.
    print(f"\nProposal written to {CONFIG_PATH}:")
    print(textwrap.indent(
        yaml.dump({"install": install_section}, default_flow_style=False),
        "  "
    ))
    print("Review and edit install-config.yaml if needed, then run `killy-install` on killy.")


if __name__ == "__main__":
    main()
