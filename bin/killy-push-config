#!/usr/bin/env bash
# killy-push-config — push updated files to the live installer on killy.
#
# Run from the build host (inside nix-shell):
#
#   bin/killy-push-config <killy-installer-ip>
#
# Pushes:
#   - killy/install-config.yaml  → /etc/nixos/killy/install-config.yaml
#   - installer/bin/killy-install → /etc/nixos/installer/bin/killy-install
#
# Both paths on the installer may be symlinks into the read-only squashfs.
# This script unlinks them first (if needed) so the overlayfs upper layer
# gets a real writable file.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [[ $# -lt 1 ]]; then
    echo "Usage: $0 <killy-installer-ip>" >&2
    exit 1
fi

HOST="$1"
SSH="ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 nixos@${HOST}"

push_file() {
    local src="$1"
    local dest="$2"
    local mode="${3:-644}"
    local tmp="/tmp/$(basename "$dest")"

    echo "killy-push-config: pushing $(basename "$dest") to ${HOST}:${dest}..."
    $SSH "if [ -L '$dest' ]; then sudo unlink '$dest'; fi"
    scp "$src" "nixos@${HOST}:${tmp}"
    $SSH "sudo mv '$tmp' '$dest' && sudo chmod $mode '$dest'"
    echo "killy-push-config: done — $($SSH "ls -lh '$dest'")"
}

push_file "$REPO_ROOT/killy/install-config.yaml"      /etc/nixos/killy/install-config.yaml        644
push_file "$REPO_ROOT/killy/modules/base.nix"         /etc/nixos/modules/base.nix                 644
push_file "$REPO_ROOT/installer/bin/killy-install"    /etc/nixos/installer/bin/killy-install      755
