#!/usr/bin/env bash
# Install NixOS on killy's disks from the live installer ISO.
#
# Run this script from the live installer SSH session on killy:
#
#   ssh nixos@<killy-ip>
#   bash /etc/nixos/bin/killy-install
#
# What this script does (spec 0005 §5.2):
#   1.  Print lsblk and ask for explicit confirmation before touching any disk.
#   2.  Wipe and partition nvme0n1 (OS drive, 512 GB).
#   3.  Create btrfs subvolumes (@, @nix, @home, @log) on nvme0n1p2.
#   4.  Mount all subvolumes and the EFI partition.
#   5.  Partition and format nvme1n1 (data drive, 2 TB).
#   6.  Generate NixOS hardware config (nixos-generate-config).
#   7.  Generate SSH host key.
#   8.  Derive and print the host age public key (operator copies to .sops.yaml).
#   9.  Wait for operator to update .sops.yaml and run sops updatekeys on the
#       build host, then push the updated install-config.yaml to the ISO.
#  10.  Copy repo to /mnt/etc/nixos.
#  11.  Run nixos-install.
#  12.  Unmount and reboot.
#
# Prerequisites (must be done before running this script):
#   - VT-x and VT-d enabled in BIOS.
#   - Static DHCP lease for killy's WiFi MAC on the router.
#   - Yubikey plugged in (for SOPS_AGE_KEY in this session).
#
set -euo pipefail

OS_DISK=/dev/nvme0n1
DATA_DISK=/dev/nvme1n1
BTRFS_OPTS="compress=zstd,noatime"

# ---------------------------------------------------------------------------
# 1. Confirm target disks
# ---------------------------------------------------------------------------

echo "=========================================="
echo "  killy NixOS installer — spec 0005"
echo "=========================================="
echo ""
echo "Target disks:"
lsblk -o NAME,SIZE,MODEL,FSTYPE,MOUNTPOINTS
echo ""
echo "This will WIPE the following disks entirely:"
echo "  OS drive:   $OS_DISK  (512 GB — NixOS root)"
echo "  Data drive: $DATA_DISK (2 TB  — /srv and /var/mail)"
echo ""
read -r -p "Type YES to proceed: " CONFIRM
if [[ "$CONFIRM" != "YES" ]]; then
    echo "Aborted."
    exit 1
fi

# ---------------------------------------------------------------------------
# 2. Partition OS drive (nvme0n1)
# ---------------------------------------------------------------------------

echo ""
echo "[1/12] Partitioning OS drive $OS_DISK..."
wipefs -a "$OS_DISK"
parted "$OS_DISK" -- mklabel gpt
parted "$OS_DISK" -- mkpart ESP fat32 1MiB 1025MiB
parted "$OS_DISK" -- set 1 esp on
parted "$OS_DISK" -- mkpart primary 1025MiB 100%
mkfs.fat -F 32 -n BOOT "${OS_DISK}p1"
mkfs.btrfs -f -L nixos "${OS_DISK}p2"

# ---------------------------------------------------------------------------
# 3. Create btrfs subvolumes
# ---------------------------------------------------------------------------

echo "[2/12] Creating btrfs subvolumes..."
mount "${OS_DISK}p2" /mnt
btrfs subvolume create /mnt/@
btrfs subvolume create /mnt/@nix
btrfs subvolume create /mnt/@home
btrfs subvolume create /mnt/@log
umount /mnt

# ---------------------------------------------------------------------------
# 4. Mount subvolumes
# ---------------------------------------------------------------------------

echo "[3/12] Mounting subvolumes..."
mount -o "$BTRFS_OPTS,subvol=@"     "${OS_DISK}p2" /mnt
mkdir -p /mnt/{boot,nix,home,var/log}
mount -o "$BTRFS_OPTS,subvol=@nix"  "${OS_DISK}p2" /mnt/nix
mount -o "$BTRFS_OPTS,subvol=@home" "${OS_DISK}p2" /mnt/home
mount -o "$BTRFS_OPTS,subvol=@log"  "${OS_DISK}p2" /mnt/var/log
mount "${OS_DISK}p1" /mnt/boot

# ---------------------------------------------------------------------------
# 5. Partition and format data drive (nvme1n1)
# ---------------------------------------------------------------------------

echo "[4/12] Partitioning data drive $DATA_DISK..."
wipefs -a "$DATA_DISK"
parted "$DATA_DISK" -- mklabel gpt
# 100 GiB for /srv (application data, VM staging)
parted "$DATA_DISK" -- mkpart primary 1MiB 102401MiB
# Remainder (~1.8 TiB) for /var/mail (Postfix spool + Dovecot mailboxes)
parted "$DATA_DISK" -- mkpart primary 102401MiB 100%
mkfs.btrfs -f -L srv  "${DATA_DISK}p1"
mkfs.btrfs -f -L mail "${DATA_DISK}p2"
mkdir -p /mnt/srv /mnt/var/mail
mount -o "$BTRFS_OPTS" "${DATA_DISK}p1" /mnt/srv
mount -o "$BTRFS_OPTS" "${DATA_DISK}p2" /mnt/var/mail

# ---------------------------------------------------------------------------
# 6. Generate NixOS hardware config
# ---------------------------------------------------------------------------

echo "[5/12] Generating hardware configuration..."
nixos-generate-config --root /mnt
# The generated file will be at /mnt/etc/nixos/hardware-configuration.nix.
# After the install, copy it to killy/system/hardware-configuration.nix in
# the repo and commit it.

# ---------------------------------------------------------------------------
# 7. Generate SSH host key
# ---------------------------------------------------------------------------

echo "[6/12] Generating SSH host key..."
mkdir -p /mnt/etc/ssh
ssh-keygen -t ed25519 -N "" -f /mnt/etc/ssh/ssh_host_ed25519_key

# ---------------------------------------------------------------------------
# 8. Derive host age key
# ---------------------------------------------------------------------------

echo "[7/12] Deriving host age key from SSH host key..."
HOST_AGE_PUBKEY=$(ssh-to-age -i /mnt/etc/ssh/ssh_host_ed25519_key.pub)
echo ""
echo "=========================================="
echo "  Host age PUBLIC key:"
echo "  $HOST_AGE_PUBKEY"
echo "=========================================="
echo ""
echo "Next steps on the BUILD HOST (separate terminal):"
echo "  1. Edit .sops.yaml — replace the killy host age recipient with:"
echo "       - $HOST_AGE_PUBKEY"
echo "  2. Run: sops updatekeys killy/install-config.yaml"
echo "  3. Commit and push (or scp the updated install-config.yaml here)."
echo ""
read -r -p "Press ENTER when install-config.yaml has been updated and pushed..."

# ---------------------------------------------------------------------------
# 10. Copy repo to disk
# ---------------------------------------------------------------------------

echo "[8/12] Copying repo to /mnt/etc/nixos..."
# The repo is mounted at /etc/nixos on the live ISO.
cp -r /etc/nixos /mnt/etc/nixos
# Copy the freshly generated hardware-configuration.nix into the system dir.
cp /mnt/etc/nixos/hardware-configuration.nix \
   /mnt/etc/nixos/killy/system/hardware-configuration.nix

# ---------------------------------------------------------------------------
# 11. Install NixOS
# ---------------------------------------------------------------------------

echo "[9/12] Running nixos-install..."
nixos-install --root /mnt --no-root-passwd \
  --flake /mnt/etc/nixos#killy

# ---------------------------------------------------------------------------
# Post-install: print hardware-configuration.nix for committing
# ---------------------------------------------------------------------------

echo ""
echo "=========================================="
echo "  ACTION REQUIRED: commit hardware-configuration.nix"
echo "=========================================="
echo ""
echo "Copy the following to killy/system/hardware-configuration.nix in the"
echo "repo on the build host and commit it:"
echo ""
cat /mnt/etc/nixos/killy/system/hardware-configuration.nix
echo ""

# ---------------------------------------------------------------------------
# 12. Unmount and reboot
# ---------------------------------------------------------------------------

echo "[10/12] Unmounting..."
umount -R /mnt

echo ""
read -r -p "Press ENTER to reboot into the installed system..."
reboot
